{
  "name": "pwo-dhamar-website",
  "version": "5.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "description": "مكتب الأشغال العامة والطرق - محافظة ذمار | البوابة الإلكترونية الرسمية - الإصدار 5.0.0",
  "author": "م. هايل البحري <m.haielalbahri@pwo-dhamar.gov.ye>",
  "license": "MIT",
  "homepage": "https://pwo-dhamar.gov.ye",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abdalmalik25/DhamarPWO.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "watch": "vite build --watch",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "start": "node preview.js",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,jsonc,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,jsonc,css,scss,md}\"",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest",
    "test:perf": "lighthouse http://localhost:8080 --view --output=html --output-path=./lighthouse-report.html",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "analyze": "node scripts/analyze-bundle.mjs",
    "clean": "rimraf dist",
    "prepare": "node scripts/copy-docs.mjs",
    "postinstall": "node scripts/copy-docs.mjs",
    "deploy": "bash deploy.sh",
    "deploy:vercel": "vercel --prod",
    "reinstall": "pnpm install && pnpm prepare",
    "check-all": "pnpm lint && pnpm typecheck && pnpm test && pnpm audit"
  },
  "keywords": [
    "municipality",
    "government",
    "engineering",
    "permits",
    "yemen",
    "dhamar",
    "infrastructure",
    "pwa",
    "government-portal",
    "arabic"
  ],
  "dependencies": {
    "@supabase/supabase-js": "2.39.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "pdf-parse": "^1.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-leaflet": "^4.2.1",
    "react-to-print": "^3.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "idb": "^8.0.3",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.35",
    "prettier": "^3.8.5",
    "rimraf": "^5.0.5",
    "serve": "^14.2.6",
    "swiper": "^14.0.0",
    "tailwindcss": "^3.4.1",
    "terser": "^5.48.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-compression2": "^2.5.3",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  },
  "engines": {
    "node": ">=18.x"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint --fix",
    "*.{css,json,md}": "prettier --write"
  }
}
