# ═══════════════════════════════════════════════════════════
# مكتب الأشغال العامة والطرق - محافظة ذمار
# Environment Variables - الإصدار 5.0.0
# ═══════════════════════════════════════════════════════════

# ┌──────────────────────────────────────────────────────────
# │ قاعدة البيانات (Supabase) - استخدم القيم الحقيقية فقط
# └──────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ┌──────────────────────────────────────────────────────────
# │ الأمان
# └──────────────────────────────────────────────────────────
VITE_APP_ENCRYPTION_KEY=your-32-char-encryption-key-here
VITE_CSRF_SECRET=your-csrf-secret-key-here

# ┌──────────────────────────────────────────────────────────
# │ API Configuration
# └──────────────────────────────────────────────────────────
VITE_API_URL=https://api.example.com
VITE_API_TIMEOUT=30000

# ┌──────────────────────────────────────────────────────────
# │ CORS Origins - أصل المواقع المسموح بها
# └──────────────────────────────────────────────────────────
VITE_ALLOWED_ORIGINS=https://pwo-dhamar.gov.ye,https://www.pwo-dhamar.gov.ye

# ┌──────────────────────────────────────────────────────────
# │ المراقبة والتحليلات (Monitoring & Analytics)
# └──────────────────────────────────────────────────────────
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# ┌──────────────────────────────────────────────────────────
# │ البريد الإلكتروني (Email Service)
# └──────────────────────────────────────────────────────────
VITE_EMAIL_SERVICE_ID=service_xxx
VITE_EMAIL_TEMPLATE_ID=template_xxx
VITE_EMAIL_USER_ID=user_xxx

# ┌──────────────────────────────────────────────────────────
# │ التخزين (Storage Limits)
# └──────────────────────────────────────────────────────────
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,png

# ┌──────────────────────────────────────────────────────────
# │ إعدادات التطبيق (App Settings)
# └──────────────────────────────────────────────────────────
VITE_APP_VERSION=5.0.0
VITE_APP_ENV=production
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_PWA=true
VITE_ENABLE_PRINT=true

# ┌──────────────────────────────────────────────────────────
# │ Session Management
# └──────────────────────────────────────────────────────────
VITE_SESSION_TIMEOUT=3600000
VITE_REFRESH_TOKEN_INTERVAL=1800000
